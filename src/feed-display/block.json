{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-feed-display/feed",
	"version": "1.0.0",
	"title": "Post Feed",
	"category": "widgets",
	"icon": "feed",
	"description": "Muestra los posts del sitio en un feed con carga lazy, imagen destacada, extracto y tags.",
	"textdomain": "wp-feed-display",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:render.php",
	"attributes": {
		"viewMode": {
			"type": "string",
			"default": "grid"
		},
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"textColor": {
			"type": "string",
			"default": "#333333"
		},
		"accentColor": {
			"type": "string",
			"default": "#0073aa"
		},
		"categories": {
			"type": "string",
			"default": ""
		},
		"tags": {
			"type": "string",
			"default": ""
		},
		"postsPerPage": {
			"type": "number",
			"default": 6
		},
		"excerptLength": {
			"type": "number",
			"default": 150
		},
		"gridColumns": {
			"type": "number",
			"default": 3
		},
		"gridButtonBg": {
			"type": "string",
			"default": "#0073aa"
		},
		"gridButtonText": {
			"type": "string",
			"default": "#ffffff"
		},
		"splitColumns": {
			"type": "number",
			"default": 2
		},
		"masonryColumns": {
			"type": "number",
			"default": 4
		},
		"masonryGap": {
			"type": "number",
			"default": 8
		},
		"masonryPadding": {
			"type": "number",
			"default": 0
		},
		"masonryOverlayBg": {
			"type": "string",
			"default": "#000000"
		},
		"masonryOverlayOpacity": {
			"type": "number",
			"default": 50
		},
		"masonryTextColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"masonryTextSize": {
			"type": "number",
			"default": 100
		},
		"masonryButtonBg": {
			"type": "string",
			"default": "#ffffff"
		},
		"masonryButtonText": {
			"type": "string",
			"default": "#000000"
		},
		"slidePosts": {
			"type": "number",
			"default": 1
		},
		"slideInterval": {
			"type": "number",
			"default": 5000
		},
		"slideTextPosition": {
			"type": "string",
			"default": "bottom"
		},
		"slideBg": {
			"type": "string",
			"default": "#000000"
		},
		"slideTextColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"slideAccentColor": {
			"type": "string",
			"default": "#0073aa"
		},
		"slideButtonBg": {
			"type": "string",
			"default": "#ffffff"
		},
		"slideButtonText": {
			"type": "string",
			"default": "#000000"
		},
		"slideArrowBg": {
			"type": "string",
			"default": "rgba(0,0,0,0.45)"
		},
		"slideArrowColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"slideArrowShape": {
			"type": "string",
			"default": "circle"
		}
	}
}
